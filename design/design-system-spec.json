              "fontSize": "17px",
              "fontWeight": 400,
              "color": "#0D0D0D"
            }
          },
          "row2": {
            "layout": "flex row space-between items-center",
            "subtitle": {
              "fontSize": "14px",
              "fontStyle": "italic",
              "color": "#9CA3AF"
            }
          },
          "row3": {
            "layout": "flex row gap-12",
            "marginTop": "16px"
          }
        },

        "primaryCTAButton": {
          "background": "#0D0D0D",
          "textColor": "#FFFFFF",
          "borderRadius": "50px",
          "paddingH": "28px",
          "paddingV": "14px",
          "fontSize": "15px",
          "fontWeight": 500,
          "minWidth": "180px",
          "states": {
            "default": {
