      "implementationGuidelines": {
        "colorApplicationRules": [
          "forestGreen (#2C4F3E) is the background fill for ALL interactive CTA surfaces — never used as text color",
          "announcementGreen (#1E3A2B) is EXCLUSIVELY for the top announcement strip — do not share with nav or cards",
          "limeAccent (#C5E042) is an accent/highlight token only — not for large content backgrounds or body text",
          "bodyText (#6B7280) is universally applied to ALL secondary/descriptive text, regardless of section background",
          "White text (#FFFFFF) is used exclusively on dark green and black surfaces"
        ],
        "shadowDistribution": [
          "Product cards: card shadow (0 4px 16px rgba(0,0,0,0.08))",
          "Feature cards: featureCard shadow (0 2px 8px rgba(0,0,0,0.06))",
          "Floating hero chips: floatingChip shadow (0 4px 12px rgba(0,0,0,0.15))",
          "Navigation bar: navigation shadow (0 1px 4px rgba(0,0,0,0.06))",
          "Shadows apply ONLY to outer container bounds — never to icon elements, text, or inner children"
        ],
        "avoid": [
          "AVOID applying limeAccent as text color — it lacks sufficient contrast on white",
          "AVOID using forestGreen (#2C4F3E) for body text — reserved for background fills",
          "AVOID applying card shadows to inline elements, icons, or text nodes",
          "AVOID rendering partner logos in full color — always apply grayscale(100%) filter at 60% opacity",
          "AVOID overriding the announcementGreen (#1E3A2B) to match forestGreen (#2C4F3E) — the depth difference is intentional"
        ],
        "ensure": [
          "ENSURE all white text on forestGreen maintains 7.2:1 contrast ratio",
          "ENSURE limeAccent text (#1A1A1A) achieves minimum 4.5:1 ratio — verified at 4.8:1",
          "ENSURE floatingChip and floatingInfoCard in hero carry explicit drop shadows — they overlap the image layer",
          "ENSURE seeMoreButton uses limeAccent fill with #1A1A1A text — not white text",
          "ENSURE communityCard text uses rgba(255,255,255,0.70) for body (not pure white) to create visual hierarchy under the heading"
        ]
      }
    }
  },

  "concept02": {
    "designSystem": {
      "colorPalette": {
        "brandTokens": {
          "brandBlack": {
            "hex": "#0D0D0D",
            "rgb": "rgb(13, 13, 13)",
            "usage": [
              "brand wordmark",
              "navigation action links",
              "product name",
              "price",
              "size selector default border",
              "primary CTA button fill"
            ],
            "textOnColor": "#FFFFFF",
            "contrastRatio": "19.8:1 (WCAG AAA)"
          },
          "pureWhite": {
            "hex": "#FFFFFF",
            "usage": [
              "product card surface",
              "product info bar",
              "size selection sheet surface",
              "size circle default fill",
              "button text on dark CTA"
            ]
          },
          "pageSurface": {
            "hex": "#F2F3F2",
            "usage": [
              "outer page canvas/background",
              "product image area within card",
              "subtle section separators"
            ],
            "note": "Barely-there cool-neutral tint — not a gray card, just the global page wash"
          },
          "sheetHeaderGray": {
            "hex": "#EBEBEB",
            "usage": ["top section of bottom sheet/drawer panel before content begins"],
            "note": "Fades seamlessly into white sheet body — no explicit border between zones"
          },
          "descriptionGray": {
            "hex": "#9CA3AF",
            "usage": [
              "italic product subtitle text",
              "utility link color (More Info, US Size Guide)",
              "carousel dot inactive state",
              "testimonial source attribution"
            ]
          },
          "urgencyGold": {
            "hex": "#C08A2A",
            "rgb": "rgb(192, 138, 42)",
            "usage": [
              "'Only X Left' stock scarcity label",
