              }
            },
            "transition": "background-color 0.1s ease, color 0.1s ease"
          },

          "urgencyIndicators": {
            "lowStock": {
              "text": "Only X Left",
              "color": "#C08A2A",
              "fontSize": "13px",
              "fontWeight": 400
            },
            "highDemand": {
              "text": "Selling Fast",
              "color": "#C08A2A",
              "fontSize": "13px",
              "fontWeight": 400
            },
            "note": "Both urgency states use the SAME gold token (#C08A2A) — do not differentiate by color"
          },

          "sheetFooter": {
            "layout": "flex row space-between items-center",
            "paddingH": "20px",
            "paddingV": "16px",
            "primaryAction": "Add to Bag — uses primaryCTAButton spec",
            "utilityAction": "US Size Guide > — uses utilityAction spec"
          }
        }
      },

      "implementationGuidelines": {
        "colorApplicationRules": [
          "urgencyGold (#C08A2A) is the SOLE non-monochrome color — use only for stock and demand copy, never for UI elements",
          "pageSurface (#F2F3F2) is background-only — never apply as text, border, or icon color",
          "sheetHeaderGray (#EBEBEB) exists only in the sheet panel header zone — must not bleed into body content area",
          "descriptionGray (#9CA3AF) is universally used for all secondary/utility text — maintain consistency"
        ],
        "shadowDistribution": [
          "productImageCard: 0 4px 24px rgba(0,0,0,0.08) — lifts card off page surface",
          "bottomSheet: 0 -2px 20px rgba(0,0,0,0.06) — upward shadow creating sheet lift",
          "productInfoBar: 0 2px 12px rgba(0,0,0,0.06) — subtle lift for info panel",
          "Page surface (#F2F3F2) receives NO shadow — it is the base layer"
        ],
        "avoid": [
          "AVOID using urgencyGold (#C08A2A) for any element outside of stock/demand urgency labels",
          "AVOID applying box-shadows to the page background (#F2F3F2) — shadows belong on white surfaces only",
          "AVOID rectangular or rounded-rect CTA buttons — the pill shape (50px radius) is non-negotiable",
          "AVOID rendering size circles as any shape other than perfect 50% circles",
          "AVOID reducing brandWordmark letter-spacing below 0.12em — it defines the brand identity",
          "AVOID adding a visible divider between sheetHeaderGray and white sheet body — the transition is seamless"
        ],
        "ensure": [
          "ENSURE all size circles maintain a consistent 1.5px border — thicker borders disrupt the minimal aesthetic",
          "ENSURE product subtitle is always italic #9CA3AF — regular weight or dark color breaks the hierarchy",
          "ENSURE primary CTA button minWidth is 180px to prevent label wrapping",
          "ENSURE brandWordmark uses uppercase + 0.12em letter-spacing at all times",
          "ENSURE only one urgency gold variant exists — low stock and selling fast share the same color token"
        ]
      }
    }
  },

  "crossConceptPatterns": {
    "sharedDesignPrinciples": [
      "Pure white (#FFFFFF) is the universal primary card/content surface in both concepts",
      "Secondary/descriptive text is always a mid-gray (concept01: #6B7280 / concept02: #9CA3AF) — never pure black or brand color",
      "Shadow philosophy: low-opacity ambient shadows only — no hard or high-contrast depth effects",
      "Border radius scales with component visual weight: micro-UI = 6-8px, cards = 12-20px, large panels/sections = 20-24px, pill = 50px",
      "CTA buttons always use the highest-contrast fill available with white (#FFFFFF) label text",
      "Interaction states communicate through background lightness — hover darkens fills, active further darkens"
    ],
    "contrastPhilosophies": {
      "concept01": "Color-forward — forest green and lime accent drive category identity and visual energy",
      "concept02": "Restraint-forward — strict monochrome with a single gold urgency signal creates luxury through whitespace and typography"
    },
    "componentConvergence": {
      "primaryCTAButton": "Both concepts use high-contrast dark fill with white text and rounded corners (8px vs 50px pill reflects brand personality)",
      "cardSurface": "Both use white on light gray page backgrounds with subtle ambient shadows",
      "secondaryText": "Both use a mid-gray token for all non-primary copy regardless of section background"
    }
  }
}
