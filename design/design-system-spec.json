          "buttonHover": "background-color 0.15s ease",
          "sizeCircleSelect": "background-color 0.1s ease, color 0.1s ease",
          "sheetReveal": "transform 0.3s cubic-bezier(0.4, 0, 0.2, 1)"
        }
      },

      "components": {
        "navigationBar": {
          "background": "#FFFFFF",
          "height": "56px",
          "paddingH": "24px",
          "borderBottom": "none",
          "shadow": "none",
          "layout": "flex row: [brand-wordmark left] | [actions right]",
          "brandWordmark": {
            "fontSize": "22px",
            "fontWeight": 700,
            "letterSpacing": "0.12em",
            "color": "#0D0D0D",
            "textTransform": "uppercase"
          },
          "navActions": {
            "items": ["Search", "Menu", "Bag: 0"],
            "color": "#0D0D0D",
            "fontSize": "14px",
            "gap": "24px",
            "bagCounter": {
              "separator": ": ",
              "count": "inline text, same weight/color as label"
            }
          }
        },

        "productImageCard": {
          "background": "#F2F3F2",
