# ── 앱 ────────────────────────────────────────────────────────────────
APP_ENV=dev
APP_NAME=ASF-Orchestrator

# ── 관리자 웹 (HTTP Basic) ────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please

# ── 소비자 API 접근 토큰 (선택) ──────────────────────────────────────
# 값이 비어 있으면 인증 없이 공개. 운영에서는 토큰 설정 권장.
CONSUMER_API_TOKEN=

# ── 캐시 ──────────────────────────────────────────────────────────────
CACHE_DB_PATH=data/cache.db
CACHE_TTL_HOURS=12

# ── 스케줄 수집 ───────────────────────────────────────────────────────
# 0 이면 자동 수집 비활성 (관리자 웹에서 수동 수집만).
COLLECT_INTERVAL_HOURS=6
# KST 시각 기반 수집 (비어있으면 COLLECT_INTERVAL_HOURS 사용)
COLLECT_TIMES_KST=08:00,18:00
SEED_SAMPLE_ON_EMPTY=true

# ── 공공데이터 API 키 ─────────────────────────────────────────────────
# MAFRA(농림축산식품부 도매시장 통합) OpenAPI 인증키
MAFRA_API_KEY=sample
# KAMIS(kamis.or.kr) 원본 Open API 인증키 (data.go.kr 래퍼 아님)
# 활용신청: https://www.kamis.or.kr/customer/reference/openapi_write.do
KAMIS_CERT_KEY=
KAMIS_CERT_ID=1

# ── Google OAuth ──────────────────────────────────────────────────────
# Google Cloud Console에서 OAuth 2.0 Client ID 생성 후 입력
GOOGLE_CLIENT_ID=

# ── JWT ───────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=30

# ── Firebase Cloud Messaging (FCM) ───────────────────────────────────
# Firebase 프로젝트 ID (FCM push 발송에 사용)
FIREBASE_PROJECT_ID=
# 서비스 계정 JSON 파일 경로
FIREBASE_SERVICE_ACCOUNT_JSON=
