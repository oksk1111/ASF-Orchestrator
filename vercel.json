{
  "version": 2,
  "installCommand": "npm install --workspace apps/web",
  "buildCommand": "npm run web:build",
  "outputDirectory": "apps/web/dist",
  "rewrites": [
    { "source": "/api/v1/:path*", "destination": "/api/index" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
